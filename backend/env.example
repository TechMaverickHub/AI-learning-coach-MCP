# ============================================
# AI Learning Coach - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# cp env.example .env

# ============================================
# LLM Provider Configuration
# ============================================
# Using Groq (FREE and fast!)
# Get your FREE API key from: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
# Available models: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768

# ============================================
# Embedding Configuration
# ============================================
# Using sentence-transformers (FREE, local - no API needed!)
# Models: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (better quality)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Use mock services when APIs are unavailable (for testing)
# Set to True to use mock embeddings/digests without API calls
USE_MOCK_SERVICES=False

# ============================================
# Vector Store Configuration
# ============================================
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=../data/vector_store

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Update these with your PostgreSQL credentials
DATABASE_NAME=ai_learning_coach
DATABASE_USER=postgres
DATABASE_PASSWORD=your_postgres_password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ============================================
# Django Configuration
# ============================================
# Generate a new secret key using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-this-to-a-random-secret-key-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================
# Django REST Framework
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Streamlit Dashboard Configuration
# ============================================
STREAMLIT_PORT=8501

# ============================================
# MCP Server Configuration
# ============================================
MCP_SERVER_PORT=8001
API_BASE_URL=http://localhost:8000/api

# ============================================
# RSS Feed Configuration
# ============================================
RSS_FETCH_INTERVAL=360
RSS_MAX_ARTICLES_PER_FEED=50

# ============================================
# RAG (Retrieval Augmented Generation) Configuration
# ============================================
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# ============================================
# Digest Generation Configuration
# ============================================
DIGEST_GENERATION_TIME=09:00

# ============================================
# Scheduling Configuration (APScheduler)
# ============================================
SCHEDULER_TIMEZONE=UTC
RSS_FETCH_INTERVAL_HOURS=6

